# API
ADMIN_PASSWORD=change-me
JWT_SECRET=dev-jwt-secret-change-me
APP_TIMEZONE=UTC
DATABASE_URL=sqlite:///./data/pksp.db
DATA_DIR=./data
CORS_ORIGINS=http://localhost:3000

# Cameras (seed DB on first boot)
CAM_IN_RTSP=rtsp://127.0.0.1:8554/demo
CAM_OUT_RTSP=
CAM_IN_DIRECTION=bidirectional
CAM_OUT_DIRECTION=out
CAM_IN_WEBRTC_PATH=demo
CAM_OUT_WEBRTC_PATH=cam_out

# Real high-quality IP camera (10.39.45.167)
# The code auto-builds the authenticated URL from these when CAM_IN_RTSP is the demo default.
# High quality path = stream1 (2560x1440 H.265). See effective_cam_in_rtsp in config.py.
# IP_CAMERA_USER=admin
# IP_CAMERA_PASS=campkspQq123
# (Optional explicit override)
# CAM_IN_RTSP=rtsp://admin:campkspQq123@10.39.45.167:554/stream1
# CAM_IN_WEBRTC_PATH=cam_in

# Vision
INSIGHTFACE_MODEL=buffalo_l
VISION_TARGET_FPS=5
MATCH_THRESHOLD=0.45
MATCH_MARGIN=0.08
COOLDOWN_SECONDS=90
MIN_DWELL_SECONDS=30
ENABLE_ANTISPOOF=false
DET_SIZE=640
MOCK_VISION=true
VISION_ENABLED=true
MIN_ENROLL_IMAGES=1

# Vision acceleration (for Intel hardware: Core + iGPU)
# ONNX_PROVIDERS=CPUExecutionProvider
# Recommended on this machine (when openvino installed):
ONNX_PROVIDERS=OpenVINOExecutionProvider,CPUExecutionProvider
ONNX_INTRA_OP_NUM_THREADS=6
ONNX_INTER_OP_NUM_THREADS=1
CAPTURE_BACKEND=auto
VISION_ADAPTIVE=false

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/ws/live
NEXT_PUBLIC_WEBRTC_BASE=http://localhost:8889
