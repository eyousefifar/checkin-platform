# API — set real secrets in a local .env (mode 0600); never commit values.
ADMIN_PASSWORD=<set-a-strong-password>
JWT_SECRET=<generate-at-least-32-bytes>
APP_TIMEZONE=UTC
DATABASE_URL=sqlite:///./data/pksp.db
DATA_DIR=./data
CORS_ORIGINS=http://localhost:3000
# Default is loopback-only. Non-loopback binds require explicit non-demo secrets.
BIND_ADDR=127.0.0.1:8000

# Cameras (seed DB on first boot). Prefer credential-free local MediaMTX paths.
# Do not put camera user:password in RTSP URL user-info in tracked files.
# Leave empty or set a credential-free MediaMTX path in private .env only.
CAM_IN_RTSP=
CAM_OUT_RTSP=
CAM_IN_DIRECTION=bidirectional
CAM_OUT_DIRECTION=out
CAM_IN_WEBRTC_PATH=demo
CAM_OUT_WEBRTC_PATH=cam_out

# Real IP camera — supply credentials only via private env vars, never in URL user-info.
# IP_CAMERA_USER=<camera-user>
# IP_CAMERA_PASS=<camera-password>
# CAM_IP=<camera-host>
# CAM_HIGH_QUALITY_PATH=stream1
# Build RTSP URLs in the local (untracked) .env or camera admin UI; do not paste user-info here.
# CAM_IN_WEBRTC_PATH=cam_in

# Vision
INSIGHTFACE_MODEL=buffalo_l
VISION_TARGET_FPS=5
MATCH_THRESHOLD=0.45
MATCH_MARGIN=0.08
COOLDOWN_SECONDS=90
MIN_DWELL_SECONDS=30
ENABLE_ANTISPOOF=false
DET_SIZE=640
MOCK_VISION=true
VISION_ENABLED=true
MIN_ENROLL_IMAGES=1
REQUIRE_REAL_VISION=false
# Enrollment upload bounds (5–10 photo scale). Names only — no secrets.
MAX_ENROLL_UPLOAD_BYTES=33554432
MAX_ENROLL_FILES=10
MAX_ENROLL_FILE_BYTES=5242880
MAX_ENROLL_IMAGE_DIM=4096
MAX_ENROLL_PIXELS=20000000

# Smart scene (door zones + walk-by suppression)
ENABLE_SMART_SCENE=true
WALKBY_MIN_DWELL_FRAMES=3
ZONE_CONFIG_DIR=./configs
# Optional quality extensions (0 = disabled)
POSE_MAX_YAW=0
BLUR_MIN_VAR=0

# Media / codec — explicit publication policy (no auto inference)
# MEDIA_SOURCE_MODE=external|copy|transcode (default external)
# external: MediaMTX only; demo/operator publishes to CAM_IN_WEBRTC_PATH
# copy: require CAM_IN_H264_RTSP, stream-copy to MEDIA_PUBLISH_PATH (default cam_in_h264)
# transcode: require CAM_IN_RTSP, H.264 encode to MEDIA_PUBLISH_PATH
# MEDIA_SOURCE_MODE=external
# MEDIA_PUBLISH_PATH=cam_in_h264
# MEDIAMTX_API_ADDR=127.0.0.1:9997
# CAM_IN_H264_RTSP=
# MEDIAMTX_BIN=mediamtx
# FFMPEG_BIN=ffmpeg
# WEBRTC_BASE=http://localhost:8889
# Remote LAN WebRTC candidates: MTX_WEBRTCADDITIONALHOSTS=<appliance-lan-ip>

# Vision acceleration (for Intel hardware: Core + iGPU)
# ONNX_PROVIDERS=CPUExecutionProvider
# Recommended on this machine (when openvino installed):
ONNX_PROVIDERS=OpenVINOExecutionProvider,CPUExecutionProvider
ONNX_INTRA_OP_NUM_THREADS=6
ONNX_INTER_OP_NUM_THREADS=1
CAPTURE_BACKEND=auto
VISION_ADAPTIVE=false

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/ws/live
NEXT_PUBLIC_WEBRTC_BASE=http://localhost:8889
